class Solution {
    public void rotate(int[][] matrix) {
        
        int n = matrix.length;
        int matrix2[][] = new int[matrix[0].length][matrix.length];

        for(int i=0; i<n;i++){
            for(int j=0;j<n;j++){
              
              matrix2[j][n-1-i]=matrix[i][j];

            }
        }

        for(int i=0;i<n;i++){
            for(int j=0;j<n;j++){

               matrix[i][j] = matrix2[i][j];
            }
        }
    }
}
